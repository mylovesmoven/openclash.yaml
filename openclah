---
mixed-port: 7890
redir-port: 7892
tproxy-port: 7895
allow-lan: true
bind-address: "*"
mode: rule
log-level: warning
ipv6: true
unified-delay: true
tcp-concurrent: true
profile:
  store-selected: true
  store-fake-ip: true
geodata-mode: true
geo-auto-update: true
geo-update-interval: 24
geox-url:
  geoip: https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geoip.dat
  geosite: https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geosite.dat
  mmdb: https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/country.mmdb
sniffer:
  enable: true
  sniff:
    TLS:
      ports:
      - 443
      - 8443
    HTTP:
      ports:
      - 80
      - 8080-8880
      override-destination: true
    QUIC:
      ports:
      - 443
      - 8443
  skip-domain:
  - Mijia Cloud
  - dlg.io.mi.com
  - "+.push.apple.com"
  - "+.googlevideo.com"
  - "+.douyin.com"
  - "+.douyincdn.com"
  - "+.douyinpic.com"
  - "+.douyinstatic.com"
  - "+.douyinliving.com"
  - "+.amemv.com"
  - "+.snssdk.com"
  - "+.byteimg.com"
  - "+.pstatp.com"
  - "+.xiaohongshu.com"
  - "+.xhscdn.com"
  - "+.xhscdn.net"
  - "+.xhslink.com"
  - "+.xhsimg.com"
tun:
  enable: true
  stack: mixed
  mtu: 1492
  dns-hijack:
  - any:53
  - tcp://any:53
  auto-route: true
  auto-detect-interface: true
  strict-route: true
proxies:
- name: 自建节点-1
  type: vless
  server: <节点1_IPv4地址> # 提示：请替换为你的节点2 IPv4 服务器地址
  port: 443
  ip-version: ipv4
  udp: true
  uuid: <你的UUID> # 提示：请替换为节点2的 UUID
  flow: xtls-rprx-vision
  packet-encoding: xudp
  encryption: none
  network: tcp
  tls: true
  servername: www.microsoft.com
  client-fingerprint: chrome
  skip-cert-verify: false
  reality-opts:
    public-key: <节点2_公钥> # 提示：请替换为节点2的 Reality Public Key
    short-id: <节点2_Short_ID> # 提示：请替换为节点2的 Reality Short ID
    spider-x: "/GuP1rLvY
- name: 自建节点-1-IPv6
  type: vless
  server: "<节点1_IPv6地址>" # 提示：请替换为你的节点1 IPv6 服务器地址，IPv6地址建议加引号
  port: 443
  ip-version: ipv6
  udp: true
  uuid: <你的UUID> # 提示：同上
  flow: xtls-rprx-vision
  packet-encoding: xudp
  encryption: none
  network: tcp
  tls: true
  servername: www.microsoft.com
  client-fingerprint: chrome
  skip-cert-verify: false
  reality-opts:
    public-key: <节点1_公钥> # 提示：同上
    short-id: <节点1_Short_ID> # 提示：同上
- name: 自建节点-2
  type: vless
  server: <节点2_IPv4地址> # 提示：请替换为你的节点2 IPv4 服务器地址
  port: 443
  ip-version: ipv4
  udp: true
  uuid: <你的UUID> # 提示：请替换为节点2的 UUID
  flow: xtls-rprx-vision
  packet-encoding: xudp
  encryption: none
  network: tcp
  tls: true
  servername: www.microsoft.com
  client-fingerprint: chrome
  skip-cert-verify: false
  reality-opts:
    public-key: <节点2_公钥> # 提示：请替换为节点2的 Reality Public Key
    short-id: <节点2_Short_ID> # 提示：请替换为节点2的 Reality Short ID
- name: 自建节点-2-IPv6
  type: vless
  server: "<节点2_IPv6地址>" # 提示：请替换为你的节点2 IPv6 服务器地址，IPv6地址建议加引号
  port: 443
  ip-version: ipv6
  udp: true
  uuid: <你的UUID> # 提示：同上
  flow: xtls-rprx-vision
  packet-encoding: xudp
  encryption: none
  network: tcp
  tls: true
  servername: www.microsoft.com
  client-fingerprint: chrome
  skip-cert-verify: false
  reality-opts:
    public-key: <节点2_公钥> # 提示：同上
    short-id: <节点2_Short_ID> # 提示：同上
proxy-groups:
- name: PROXY
  type: select
  proxies:
  - AUTO
  - Vless-HK
  - 自建节点-1-IPv6
  - 自建节点-2
  - 自建节点-2-IPv6
  - DIRECT
- name: AUTO
  type: url-test
  proxies:
  - Vless-HK
  - 自建节点-1-IPv6
  - 自建节点-2
  - 自建节点-2-IPv6
